generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  AGENTE
  SUPERVISOR
  ADMINISTRADOR
}

enum TicketStatus {
  ABIERTO
  EN_PROCESO_INTERNO
  EN_ESPERA_CLIENTE
  CERRADO
}

enum SenderType {
  CLIENTE
  AGENTE
}

enum SendStatus {
  ENVIADO
  ERROR
  PENDIENTE
}

model Profile {
  id             String          @id // UUID assigned by Supabase Auth
  email          String          @unique
  full_name      String
  role           UserRole        @default(AGENTE)
  is_active      Boolean         @default(true)
  created_at     DateTime        @default(now())

  // Relations
  tickets         Ticket[]        @relation("AssignedAgent")
  messages        Message[]       @relation("MessageAuthor")
  status_changes  StatusHistory[] @relation("ChangedByAgent")
  ticket_views    TicketView[]    @relation("UserTicketViews")
  internal_notes  InternalNote[]  @relation("InternalNoteAuthor")
}

model Category {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())

  tickets     Ticket[]
}

model Ticket {
  id                   Int          @id @default(autoincrement())
  subject              String
  content              String
  status               TicketStatus @default(ABIERTO)
  client_email         String
  client_name          String?
  client_rut           String?
  client_phone         String?
  client_address       String?
  enrichment_note      String?
  category_id          Int?
  assigned_to          String?
  created_at           DateTime     @default(now())
  updated_at           DateTime     @updatedAt
  closed_at            DateTime?
  last_client_reply_at DateTime?
  deleted_at           DateTime?

  // Relations
  category             Category?    @relation(fields: [category_id], references: [id])
  agent                Profile?     @relation("AssignedAgent", fields: [assigned_to], references: [id])
  messages             Message[]
  status_history       StatusHistory[]
  views                TicketView[] @relation("TicketViews")
  internal_notes       InternalNote[]

  // Índices para optimizar queries frecuentes
  @@index([status, deleted_at])
  @@index([assigned_to, deleted_at])
  @@index([deleted_at])
  @@index([created_at])
  @@index([client_email])
  @@index([updated_at])
}

model Message {
  id                Int        @id @default(autoincrement())
  ticket_id         Int
  sender_type       SenderType
  author_id         String?
  body              String
  message_id_header String?    @unique
  send_status       SendStatus @default(ENVIADO)
  sent_at           DateTime   @default(now())

  // Relations
  ticket            Ticket     @relation(fields: [ticket_id], references: [id])
  author            Profile?   @relation("MessageAuthor", fields: [author_id], references: [id])
  attachments       Attachment[]

  // Índices para optimizar queries frecuentes
  @@index([ticket_id])
  @@index([sent_at])
  @@index([author_id])
}

model Attachment {
  id            Int      @id @default(autoincrement())
  message_id    Int
  file_name     String
  storage_path  String
  mime_type     String
  file_size     Int?
  upload_status String   @default("OK")
  upload_error  String?
  created_at    DateTime @default(now())

  // Relations
  message       Message  @relation(fields: [message_id], references: [id])

  // Índice para cargar adjuntos de un mensaje
  @@index([message_id])
}

model StatusHistory {
  id               Int          @id @default(autoincrement())
  ticket_id        Int
  previous_status  TicketStatus?
  new_status       TicketStatus
  changed_by       String?
  is_system_action Boolean      @default(false)
  changed_at       DateTime     @default(now())

  // Relations
  ticket           Ticket       @relation(fields: [ticket_id], references: [id])
  agent            Profile?     @relation("ChangedByAgent", fields: [changed_by], references: [id])

  // Índice para cargar historial de un ticket
  @@index([ticket_id])
}

model Customer {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  rut       String?
  telefono  String?
  direccion String?
  synced_at DateTime @default(now()) @updatedAt
}

model SystemConfig {
  key         String   @id
  value       String
  description String?
  updated_at  DateTime @updatedAt
}

model EmailTemplate {
  key         String   @id
  subject     String
  body        String
  description String?
  updated_at  DateTime @updatedAt
}

model FilteredEmail {
  id            Int      @id @default(autoincrement())
  from_email    String
  from_name     String?
  subject       String
  body_preview  String   // Primeros 500 caracteres del cuerpo
  score         Int      // Puntuación total que activó el filtro
  reasons       String   // Lista de motivos separados por comas
  filtered_at   DateTime @default(now())

  @@index([filtered_at])
  @@index([from_email])
}

model TicketView {
  user_id    String
  ticket_id  Int
  viewed_at  DateTime @default(now()) @updatedAt

  // Relations
  user       Profile  @relation("UserTicketViews", fields: [user_id], references: [id])
  ticket     Ticket   @relation("TicketViews", fields: [ticket_id], references: [id])

  @@id([user_id, ticket_id])
  @@index([ticket_id])
  @@index([user_id])
}

model InternalNote {
  id         Int      @id @default(autoincrement())
  ticket_id  Int
  author_id  String
  body       String
  created_at DateTime @default(now())

  // Relations
  ticket     Ticket   @relation(fields: [ticket_id], references: [id])
  author     Profile  @relation("InternalNoteAuthor", fields: [author_id], references: [id])

  // Índice para cargar notas de un ticket ordenadas por fecha
  @@index([ticket_id, created_at])
  @@index([author_id])
}
